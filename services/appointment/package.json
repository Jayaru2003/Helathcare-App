{
  "name": "@healthbridge/appointment",
  "version": "1.0.0",
  "description": "HealthBridge Appointment Service - Scheduling, conflict detection, Kafka events",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.8.1",
    "zod": "^3.22.4",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.1",
    "@healthbridge/logger": "*",
    "@healthbridge/errors": "*",
    "@healthbridge/middleware": "*",
    "@healthbridge/dto": "*",
    "@healthbridge/kafka": "*"
  },
  "devDependencies": {
    "prisma": "^5.8.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2"
  }
