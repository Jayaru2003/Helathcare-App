NODE_ENV=development
PORT=3004

# MongoDB Atlas (copy to .env and set your password; encode # as %23 in the URI)
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/healthbridge?retryWrites=true&w=majority&appName=healthbridge-prescription

# Local Docker MongoDB (default docker-compose without Atlas)
MONGODB_URI=mongodb://healthbridge:healthbridge_secret@mongodb:27017/healthbridge?authSource=admin

JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Docker: kafka:29092 | Local dev: localhost:9092
KAFKA_BROKERS=kafka:29092
KAFKA_GROUP_ID=prescription-service-group
LOG_LEVEL=info
