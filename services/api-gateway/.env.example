# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Downstream Service URLs ───────────────────────────────────────────────────
# Production (ECS Fargate): Uses AWS Cloud Map private DNS — stable names that
# never change even when Fargate tasks are replaced and get new private IPs.
# The CI/CD pipeline injects these into the ECS task definition automatically.
#
# Local development: Use localhost (services run directly on host).
# Docker Compose: Use service hostnames (auth, patient, appointment, etc.).
#
# Production values (injected by CI — do not set manually in ECS):
#   AUTH_SERVICE_URL=http://auth.healthbridge.local:3001
#   PATIENT_SERVICE_URL=http://patient.healthbridge.local:3002
#   APPOINTMENT_SERVICE_URL=http://appointment.healthbridge.local:3003
#   PRESCRIPTION_SERVICE_URL=http://prescription.healthbridge.local:3004
#   BILLING_SERVICE_URL=http://billing.healthbridge.local:3005
#   NOTIFICATION_SERVICE_URL=http://notification.healthbridge.local:3006
#   ANALYTICS_SERVICE_URL=http://analytics.healthbridge.local:3007
AUTH_SERVICE_URL=http://localhost:3001
PATIENT_SERVICE_URL=http://localhost:3002
APPOINTMENT_SERVICE_URL=http://localhost:3003
PRESCRIPTION_SERVICE_URL=http://localhost:3004
BILLING_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006
ANALYTICS_SERVICE_URL=http://localhost:3007

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS: sliding window in milliseconds (default 60 000 = 1 min)
# RATE_LIMIT_MAX:       max requests per IP per window  (default 100)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend origin in production, e.g. https://app.healthbridge.io
# Use * for development / open access
CORS_ORIGIN=*

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── JWT (optional — forward raw Authorization header to auth service) ─────────
# The gateway does NOT validate JWTs itself; it forwards them to the auth service.
# JWT_SECRET is listed here only so local tooling knows the format.
JWT_SECRET=your-super-secret-jwt-key-change-in-production
