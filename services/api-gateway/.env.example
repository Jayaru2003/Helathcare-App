# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Service URLs (internal Docker network)
AUTH_SERVICE_URL=http://auth:3001
PATIENT_SERVICE_URL=http://patient:3002
APPOINTMENT_SERVICE_URL=http://appointment:3003
PRESCRIPTION_SERVICE_URL=http://prescription:3004
BILLING_SERVICE_URL=http://billing:3005
NOTIFICATION_SERVICE_URL=http://notification:3006
ANALYTICS_SERVICE_URL=http://analytics:3007

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
