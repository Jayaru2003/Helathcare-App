{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@healthbridge/logger": ["libs/logger/src/index.ts"],
      "@healthbridge/errors": ["libs/errors/src/index.ts"],
      "@healthbridge/dto": ["libs/dto/src/index.ts"],
      "@healthbridge/kafka": ["libs/kafka/src/index.ts"],
      "@healthbridge/middleware": ["libs/middleware/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
